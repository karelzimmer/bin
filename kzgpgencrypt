origin=$(xdg-user-dir PROJECTS)

# #############################################################################
# Main
# #############################################################################

gpg --output "$origin/kz-scripts/usr/bin/kz-install.sh.gpg" \
    --sign   ~/kz-install-decrypted.sh
gpg --output "$origin/kz-scripts/usr/bin/kz-setup.sh.gpg"   \
    --sign   ~/kz-setup-decrypted.sh

printf '\n%s\n' 'Use "kzgpgdelete" to delete the decrypted kz GPG files.'
printf '\n%s\n' 'Use "kzgpgdecrypt" to decrypt the kz GPG files.'
