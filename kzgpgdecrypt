gpg --no-verbose --output  ~/kz-install-decrypted.sh    \
    --decrypt ~/kz-scripts/usr/bin/kz-install.sh.gpg    2> /dev/null
gpg --no-verbose --output  ~/kz-setup-decrypted.sh      \
    --decrypt ~/kz-scripts/usr/bin/kz-setup.sh.gpg      2> /dev/null

printf  '\n%s\n' \
        'Use "kzgpgencrypt" or "kzgpgsign" to encrypt (sign) the kz GPG files.'
