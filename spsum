# #############################################################################
# Constants
# #############################################################################

# List NORMAL last here so that -x doesn't bork the display.
readonly GREEN='\033[1;32m'
readonly NORMAL='\033[0m'


# #############################################################################
# Globals
# #############################################################################

declare ISO=''
declare searchdir=$HOME/Downloads
declare sha256sum=''


# #############################################################################
# Main
# #############################################################################

cd "$searchdir" || exit 1

for ISO in *.iso; do
    if test -e "$ISO".sha256; then
        printf '%s\n' "Checksum file $ISO.sha256 already created."
        continue
    fi
    # shellcheck disable=SC2062
    sha256sum=$(
        grep    --word-regexp           \
                --regexp=" $ISO$"       \
                --regexp=' *'"$ISO$"    \
                --regexp='('"$ISO"')'   \
                --exclude=*.iso         \
                --exclude="$ISO".sha256 \
                --exclude-dir=*         \
                --no-filename           \
                -- *                    || true 
                )
    if [[ -z $sha256sum ]]; then
        printf '%s\n' "No checksum found for $ISO." >&2
    else
        echo "$sha256sum" > "$ISO".sha256
        printf '%s\n' "Checksum file $ISO.sha256 created."
    fi
done
printf  '\n%s\n%s\n\n%s\n'                                      \
        'To check the image files execute:'                     \
        "cd $searchdir; sha256sum --check *.iso.sha256; cd -"   \
        'To remove the checksum files execute:'
find "$searchdir/"*{sum,SUM,256.}* -printf 'rm %p\n' 2>/dev/null

printf '%b\n' "${GREEN}Klaar!${NORMAL}"
exit 0
