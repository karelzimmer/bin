# SPDX-License-Identifier: CC0-1.0
# #############################################################################
        
# List NORMAL last here so that -x doesn't bork the display.
bold='\033[1m'
green=$bold'\033[32m'
normal=$bold'\033[0m'

# Where the the code is stored locally.
origin=$(xdg-user-dir PROJECTS)

user_name='karelzimmer'
repo=''
repos=''

# #############################################################################
# Main
# #############################################################################

# Get all public repositories for <user_name> with curl via GitHub REST API,
# and extract required info with jq when available.
if type jq &> /dev/null; then
    repos=$(
        curl --silent "https://api.github.com/users/$user_name/repos"   |
        jq '.[] | {name: .name}'                                        |
        jq --raw-output .name
        )
else
    repos=$(
        curl --silent "https://api.github.com/users/$user_name/repos"   |
        grep --regexp='"full_name"'                                     |
        cut --delimiter=':' --fields=2-                                 |
        sed --expression='s/,//'                                        |
        sed --expression='s/"//g'                                       |
        sed --expression="s|$user_name/||"
        )
fi

for repo in $repos; do
    # Skip special repository.
    if [[ $repo = "$user_name" ]]; then
        continue
    fi
    printf "${bold}Clone %s...${normal}\n" "$origin/$repo"
    git clone "https://github.com/$user_name/$repo.git" "$origin/$repo" || true
    printf '\n'
done

printf '%b\n' "${green}Klaar!${normal}"
exit 0
