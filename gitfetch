# #############################################################################
# Constants
# #############################################################################

# List NORMAL last here so that -x doesn't bork the display.
readonly BOLD='\033[1m'
readonly GREEN='\033[1;32m'
readonly NORMAL='\033[0m'


# #############################################################################
# Globals
# #############################################################################

declare REPO=''


# #############################################################################
# Main
# #############################################################################

printf '%s\n' 'Zoek naar alle Git-repositories in de Persoonlijke map...'

while read -r REPO; do
    printf "\n${BOLD}Fetch %s...${NORMAL}" "$REPO"
    cd "$HOME/$REPO" || exit 1
    git fetch --all --verbose
done < <(
        find    "$HOME"         \
                -type   d       \
                -name   '.git'  \
                -printf '%P\n'  |
        sed     's|/.git||'     |
        sort
        )

printf '%b\n' "${GREEN}Klaar!${NORMAL}"
exit 0
