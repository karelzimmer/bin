# #############################################################################
# Imports
# #############################################################################

export TEXTDOMAIN=kz
export TEXTDOMAINDIR=/usr/share/locale
source /usr/bin/gettext.sh


# #############################################################################
# Constants
# #############################################################################

SEPARATOR_LINE=$(eval printf '=%.0s' '{1..79}')
readonly SEPARATOR_LINE
readonly FILLER='    '


# #############################################################################
# Globals
# #############################################################################


# #############################################################################
# Main
# #############################################################################

# Script-hardening.
set -o errexit
set -o errtrace
set -o nounset
set -o pipefail

# Trap exit signal.
trap 'exit $?' EXIT

# Main.
printf '%s\n' "$SEPARATOR_LINE"
printf '%s\n' ""
printf '%s\n' "$(gettext '*** git squash merge in 10 steps ***')"
printf '%s\n' ""
printf '%s\n' "$(gettext "Works best in two separate terminals by copying and \
pasting.")"
printf '%s\n' ""
printf '%s\n' "$(gettext 'The following will be executed:')"
printf '%s\n' ""
printf '%s\n' "$(gettext 'PREPARE:')"
printf '%s\n' "${FILLER}git branch              # note branch to be squashed"
printf '%s\n' "${FILLER}branch=                 # set squash branch name here"
printf '%s\n' ""
printf '%s\n' "$(gettext 'MERGE:')"
printf '%s\n' "${FILLER}git switch main"
printf '%s\n' "${FILLER}git merge --squash \$branch"
printf '%s\n' ""
printf '%s\n' "$(gettext 'COMMIT:')"
printf '%s\n' "${FILLER}git commit              # set commit message in editor"
printf '%s\n' "${FILLER}git push origin"
printf '%s\n' ""
printf '%s\n' "$(gettext 'CLEANUP:')"
printf '%s\n' "${FILLER}git branch --delete \$branch"
printf '%s\n' "${FILLER}git push origin --delete \$branch"
printf '%s\n' ""
printf '%s\n' "$(gettext 'MAINTENANCE:')"
printf '%s\n' "${FILLER}git remote prune origin # remove all stale branches"
printf '%s\n' "${FILLER}git fetch --prune       # remove all stale references"
printf '%s\n' ""
printf '%s\n' "$SEPARATOR_LINE"
exit 0
