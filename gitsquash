# #############################################################################
# Imports
# #############################################################################

export TEXTDOMAIN=kz
export TEXTDOMAINDIR=/usr/share/locale
source /usr/bin/gettext.sh


# #############################################################################
# Constants
# #############################################################################

SEPARATOR_LINE=$(eval printf -- '-%.0s' '{1..80}')
readonly SEPARATOR_LINE

# List NORMAL last here so that -x doesn't bork the display.
readonly BOLD='\033[1m'
readonly GREEN=$BOLD'\033[32m'
readonly NORMAL='\033[0m'


# #############################################################################
# Globals
# #############################################################################


# #############################################################################
# Main
# #############################################################################

# Script-hardening.
set -o errexit
set -o errtrace
set -o nounset
set -o pipefail

# Trap exit signal.
trap 'exit $?' EXIT

printf '\n%s\n\n' "$SEPARATOR_LINE"

printf '%s\n' "$(gettext '*** git squash merge in 10 steps ***')"
printf '%s\n' ""
printf '%s\n' "$(gettext 'The following will be executed:')"
printf '%s\n' ""
printf '%s\n' " 1. git branch                # note the branch to be squashed"
printf '%s\n' " 2. branch=                   # set the squash branch name here"
printf '%s\n' ""
printf '%s\n' " 3. git switch main"
printf '%s\n' " 4. git merge --squash \$branch"
printf '%s\n' ""
printf '%s\n' " 5. git commit --message=''   # set your commit message here"
printf '%s\n' " 6. git push origin"
printf '%s\n' ""
printf '%s\n' " 7. git branch --delete \$branch"
printf '%s\n' " 8. git push origin --delete \$branch"
printf '%s\n' ""
printf '%s\n' " 9. git remote prune origin   # remove all stale branches"
printf '%s\n' "10. git fetch --prune         # remove any no longer existing \
remote references"
printf '%s\n' ""
printf '%b\n' "${GREEN}$(gettext 'Complete!')${NORMAL}"
printf '\n%s\n\n' "$SEPARATOR_LINE"
exit 0
