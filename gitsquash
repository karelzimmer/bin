# #############################################################################
# Imports
# #############################################################################

export TEXTDOMAIN=kz
export TEXTDOMAINDIR=/usr/share/locale
source /usr/bin/gettext.sh


# #############################################################################
# Constants
# #############################################################################

SEPARATOR_LINE=$(eval printf -- '=%.0s' '{1..79}')
readonly SEPARATOR_LINE


# #############################################################################
# Globals
# #############################################################################


# #############################################################################
# Main
# #############################################################################

# Script-hardening.
set -o errexit
set -o errtrace
set -o nounset
set -o pipefail

# Trap exit signal.
trap 'exit $?' EXIT

# Main.
printf '%s\n' "$SEPARATOR_LINE

$(gettext '*** git squash merge in 10 steps ***')

$(gettext "Works best in two separate terminals by copying and pasting.")

$(gettext 'The following will be executed:')

$(gettext 'PREPARE')
    1.  git branch              # note branch to be squashed
    2.  branch=                 # set squash branch name here

$(gettext 'MERGE')
    3.  git switch main
    4.  git merge --squash \$branch

$(gettext 'COMMIT')
    5.  git commit              # set commit message in editor
    6.  git push origin

$(gettext 'CLEANUP')
    7.  git branch --delete \$branch
    8.  git push origin --delete \$branch

$(gettext 'MAINTENANCE')
    9.  git remote prune origin # remove all stale branches
   10.  git fetch --prune       # remove all stale references

$SEPARATOR_LINE"
exit 0
