# List NORMAL last here so that -x doesn't bork the display.
BOLD='\033[1m'
GREEN='\033[1;32m'
NORMAL='\033[0m'

declare repo=''


# #############################################################################
# Main
# #############################################################################

while read -r repo; do
    printf "${BOLD}Status %s...${NORMAL}\n" "$repo"
    cd "$HOME/$repo" || exit 1
    git status --verbose
    printf '\n'
done < <(
        find    "$HOME"         \
                -type   d       \
                -name   '.git'  \
                -printf '%P\n'  |
        sed     's|/.git||'     |
        sort
        )

printf '%b\n' "${GREEN}Klaar!${NORMAL}"
exit 0
