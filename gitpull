# #############################################################################
# Imports
# #############################################################################

source common.sh
export TEXTDOMAIN=kz
export TEXTDOMAINDIR=/usr/share/locale
source /usr/bin/gettext.sh


# #############################################################################
# Constants
# #############################################################################


# #############################################################################
# Globals
# #############################################################################

declare REPO=''


# #############################################################################
# Functions
# #############################################################################


# #############################################################################
# Main
# #############################################################################

while read -r REPO; do
    printf "${BOLD}Pull %s...$NORMAL\n" "$REPO"
    cd "$REPO"
    git pull --all --verbose
    printf '\n'
done < <(
        find    "$ORIGIN"   \
                -maxdepth 2 \
                -name .git  \
                -type d     \
                -print      |
        sort                |
        sed     --expression='s|/.git||'
        )

complete_exit
