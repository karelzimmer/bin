# List NORMAL last here so that -x doesn't bork the display.
green='\033[1;32m'
normal='\033[0m'

# Where the the code is stored locally.
origin=$(xdg-user-dir PROJECTS)

# #############################################################################
# Main
# #############################################################################

# Fill ~/bin with repo bin.
rsync   --archive               \
        --verbose               \
        --exclude='LICENSE'     \
        --exclude='README.md'   \
        --exclude='.git*'       \
        "$origin/bin"           \
        "$HOME"

printf '%b\n' "${green}Klaar!${normal}"
exit 0
